########################################
# TTS-STT Services Configuration        #
########################################

# ===========================================
# HOST PORT CONFIGURATION
# ===========================================
# Change these if ports conflict with other services on your machine
FRONTEND_PORT=3000
PIPER_TTS_PORT=5000
STT_PORT=5001
QWEN3_ASR_PORT=5002
QWEN3_TTS_PORT=5004
TRAINING_PORT=8080

# ===========================================
# HARDWARE ACCELERATION
# ===========================================
# GPU device selection (0 for first GPU, 1 for second, etc.)
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
# Optional override: cuda | rocm | cpu (leave empty to auto-detect)
FORCE_ACCELERATION=

# --- ROCm / AMD GPU (used with docker-compose.rocm.yml) ---
# AMD GPU device index
HIP_VISIBLE_DEVICES=0
# GFX version override for unsupported AMD GPUs (e.g. Strix Halo gfx1201 → 11.0.0)
# Leave empty if your GPU is natively supported by ROCm 6.2
HSA_OVERRIDE_GFX_VERSION=

# ===========================================
# STT SERVICE (Whisper Speech-to-Text)
# ===========================================
# Whisper model size: tiny | base | small | medium | large-v3
# tiny: ~39MB, fast but lower accuracy
# base: ~74MB, balanced speed/accuracy
# small: ~244MB, good accuracy
# medium: ~769MB, high accuracy
# large-v3: ~1550MB, best accuracy
WHISPER_MODEL_SIZE=small

# ===========================================
# QWEN3 SERVICES
# ===========================================
# Qwen3-TTS model (voice cloning + TTS)
QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# Qwen3-ASR model (speech recognition)
QWEN3_ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# ===========================================
# VOICE TRAINING SERVICE
# ===========================================
# PyTorch CUDA memory for training (larger allocation for training)
TRAINING_PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:1024
# OpenMP thread count for CPU operations
OMP_NUM_THREADS=4

# ===========================================
# WEB INTERFACE & CORS
# ===========================================
# Comma-separated list of allowed origins; set to specific URLs for production
ALLOWED_ORIGINS=*
ALLOW_CREDENTIALS=false

# ===========================================
# OPTIONAL DEVELOPMENT SETTINGS
# ===========================================
ENVIRONMENT=production
DEBUG=false
