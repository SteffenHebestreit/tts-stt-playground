# Hardware Acceleration Settings
# USE_CUDA: Controls CUDA usage (auto=detect, true=force, false=disable)
USE_CUDA=auto

# FORCE_ACCELERATION: Override hardware detection (cuda, rocm, cpu)
# Leave empty for automatic detection
FORCE_ACCELERATION=

# Coqui TTS License Agreement
# Automatically accept CPML license for non-commercial use
COQUI_TOS_AGREED=1

# TTS Service Settings
# Default language for TTS synthesis (supported: en, es, fr, de, it, pt, pl, tr, ru, nl, cs, ar, zh-cn, ja, hu, ko, hi)
TTS_LANGUAGE=de

# STT Service Settings
# Available models: tiny, base, small, medium, large-v3
# Larger models = better accuracy but slower inference
WHISPER_MODEL_SIZE=medium

# Translation Settings
# DEFAULT_TRANSLATION_TARGET: Default target language for translation tasks
DEFAULT_TRANSLATION_TARGET=german

# Streaming Settings
# STT_CHUNK_SIZE: Characters per chunk for streaming transcription
STT_CHUNK_SIZE=200
# TTS_CHUNK_SIZE: Characters per chunk for streaming synthesis  
TTS_CHUNK_SIZE=200

# Performance Settings (uncomment to customize)
# WORKERS=1

# GPU Configuration Examples:
# For NVIDIA GPU:
# USE_CUDA=true
# FORCE_ACCELERATION=cuda

# For AMD GPU (ROCm):
# USE_CUDA=false
# FORCE_ACCELERATION=rocm

# For CPU only:
# USE_CUDA=false
# FORCE_ACCELERATION=cpu
